---
import type { CollectionEntry } from "astro:content";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props as Props;
---

<a
  href={`/projects/${project.id}`}
  class="flex gap-3 not-prose group block overflow-hidden rounded-xl border border-black/15 bg-white p-3 transition-all duration-300 ease-in-out hover:-translate-y-0.5 hover:border-black/30 hover:shadow-sm focus-visible:-translate-y-0.5 focus-visible:border-black/30 focus-visible:shadow-sm dark:border-white/20 dark:bg-neutral-900 dark:hover:border-white/40 dark:focus-visible:border-white/40"
>
  <div class="w-32 overflow-hidden rounded-lg border border-black/10 dark:border-white/10">
    <img
      src={project.data.image ?? "/astro-sphere.jpg"}
      alt={`Preview image for ${project.data.title}`}
      class="aspect-[16/10] w-full object-cover transition-transform duration-500 ease-out group-hover:scale-[1.03] group-focus-visible:scale-[1.03]"
      loading="lazy"
    />
  </div>
  <div class="mt-4 space-y-3">
    <h3 class="text-lg font-semibold text-black dark:text-white">{project.data.title}</h3>
    {
      project.data.tags && project.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-2">
          {project.data.tags.map((tag) => <li class="rounded-full border border-black/15 px-2 py-1 text-xs font-medium text-black/70 dark:border-white/20 dark:text-white/70">{tag}</li>)}
        </ul>
      )
    }
    <p class="text-sm text-black/70 dark:text-white/70">{project.data.description}</p>
  </div>
</a>